{
  "name": "winget-gui",
  "version": "0.1.9",
  "private": true,
  "description": "Electron GUI for selecting and running winget package upgrades.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "electron": "electron .",
    "dev:app": "concurrently -k \"npm run dev\" \"wait-on http://127.0.0.1:5317 && electron .\"",
    "build": "vite build",
    "desktop": "npm run build && electron . --dist",
    "package:portable": "npm run build && node scripts/package-portable.cjs",
    "release:win": "npm run build && electron-builder --win portable nsis --x64 --publish never",
    "portable": "npm run package:portable",
    "preview": "npm run desktop",
    "start": "npm run desktop",
    "test": "node --test tests/*.test.cjs"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.1.2",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "lucide-react": "^0.468.0",
    "pretendard": "^1.3.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.3.0",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.est.winget-gui",
    "productName": "Winget GUI",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "requireAdministrator",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "Winget-GUI-Portable-${version}-${arch}.${ext}",
      "requestExecutionLevel": "admin"
    },
    "nsis": {
      "artifactName": "Winget-GUI-Setup-${version}-${arch}.${ext}",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
